{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start local web server",
            "type": "shell",
            "isBackground": true,
            "command": "node scripts/dev-server.js",
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "."
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Server running at http://127.0.0.1:8080"
                }
            }
        }
    ]
}
